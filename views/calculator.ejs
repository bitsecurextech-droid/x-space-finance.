<script>
document.addEventListener('DOMContentLoaded', function() {
  const planSelect = document.getElementById('calc-plan');
  const amountInput = document.getElementById('calc-amount');
  const rangeText = document.getElementById('calc-range');
  const submitBtn = document.getElementById('calc-submit');
  const resultsDiv = document.getElementById('calc-results');
  const placeholderDiv = document.getElementById('calc-placeholder');

  function updateRange() {
    const opt = planSelect.selectedOptions[0];
    const min = parseFloat(opt.dataset.min);
    const max = parseFloat(opt.dataset.max);
    rangeText.textContent = 'Min: $' + min.toLocaleString() + ' — Max: $' + max.toLocaleString();
    amountInput.min = min;
    amountInput.max = max;
  }

  planSelect.addEventListener('change', updateRange);
  updateRange();

  submitBtn.addEventListener('click', function() {
    const opt = planSelect.selectedOptions[0];
    const amount = parseFloat(amountInput.value);

    if (!amount || amount < parseFloat(opt.dataset.min) || amount > parseFloat(opt.dataset.max)) {
      alert('Please enter a valid amount within the plan range.');
      return;
    }

    const rate = parseFloat(opt.dataset.rate);
    const days = parseInt(opt.dataset.days);
    const durationLabel = opt.dataset.duration;
    const planName = opt.dataset.name;

    // Simple interest: A = P * (1 + rate/100)
    const totalReturn = amount * (1 + rate / 100);
    const profit = totalReturn - amount;
    const effectiveRoi = rate;

    const maturityDate = new Date();
    maturityDate.setDate(maturityDate.getDate() + days);

    document.getElementById('res-plan').textContent = planName;
    document.getElementById('res-principal').textContent = '$' + amount.toLocaleString(undefined, {minimumFractionDigits: 2});
    document.getElementById('res-duration').textContent = durationLabel;
    document.getElementById('res-rate').textContent = rate.toFixed(2) + '%';
    document.getElementById('res-total').textContent = '$' + totalReturn.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
    document.getElementById('res-profit').textContent = '+$' + profit.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
    document.getElementById('res-roi').textContent = effectiveRoi.toFixed(2) + '%';
    document.getElementById('res-maturity').textContent = maturityDate.toLocaleDateString('en-US', {year: 'numeric', month: 'long', day: 'numeric'});

    placeholderDiv.classList.add('hidden');
    resultsDiv.classList.remove('hidden');
  });
});
</script>
