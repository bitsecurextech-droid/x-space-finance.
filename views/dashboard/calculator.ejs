<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Calculator - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
   <style>
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.2s; color: #64748b; }
    .sidebar-link:hover { background: #f1f5f9; color: #1e293b; }
    .sidebar-link.active { background: #e0f2fe; color: #0284c7; }
    .sidebar-icon { width: 20px; height: 20px; }
    .sidebar-section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; margin-bottom: 8px; padding-left: 12px; }
    .topbar { background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 40; }
    .investment-card { transition: all 0.2s; }
    .investment-card:hover { transform: translateY(-2px); box-shadow: 0 8px 25px -6px rgba(0,0,0,0.1); }
  </style>
</head>
<body>

  <div class="flex">
    <!-- Sidebar -->
    <%- include('../partials/complete-sidebar') %>

    <!-- Main Content -->
    <div class="flex-1 lg:ml-64">
      <!-- TOPBAR (partial) -->
      <%- include('../partials/topbar') %>

      <div class="p-6">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
          <!-- Left Column - Calculator Form -->
          <div class="lg:col-span-3 space-y-6">
            <!-- Calculator Card -->
            <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
              <div class="px-5 py-3.5 border-b border-slate-100">
                <h2 class="text-sm font-semibold text-slate-800">Enter Details</h2>
              </div>
              <div class="p-5 space-y-5">
                <div>
                  <label class="text-xs font-medium text-slate-500 mb-1.5 block">Select Plan</label>
                  <select id="calcPlan" class="w-full border border-slate-200 rounded-lg px-3.5 py-2.5 text-sm text-slate-800 focus:ring-2 focus:ring-slate-300 focus:border-slate-300 transition outline-none">
                    <!-- All plans: min $100, max $1,000,000 -->
                    <option value="1" data-min="100" data-max="1000000" data-roi="200" data-months="1" data-days="30" data-name="108 Circle" data-type="simple">108 Circle (1 month · 200% ROI)</option>
                    <option value="2" data-min="100" data-max="1000000" data-roi="200" data-months="1" data-days="30" data-name="2222 Investment" data-type="simple">2222 Investment (1 month · 200% ROI)</option>
                    <option value="3" data-min="100" data-max="1000000" data-roi="300" data-months="1" data-days="30" data-name="8888 Investment" data-type="simple">8888 Investment (1 month · 300% ROI)</option>
                    <option value="4" data-min="100" data-max="1000000" data-roi="350" data-months="1" data-days="30" data-name="Tier 3 Investment" data-type="simple">Tier 3 Investment (1 month · 350% ROI)</option>
                    <!-- Bitcoin Elite Group: min $1,000, max $1,000,000 -->
                    <option value="5" data-min="1000" data-max="1000000" data-roi="750" data-months="0.5" data-days="14" data-name="Bitcoin Elite Group" data-type="compound">Bitcoin Elite Group (2 weeks · 750% ROI)</option>
                  </select>
                </div>
                
                <!-- Plan Info Boxes -->
                <div id="planInfo" class="grid grid-cols-2 sm:grid-cols-4 gap-3 p-3.5 bg-slate-50 rounded-lg border border-slate-100">
                  <div>
                    <p class="text-[10px] text-slate-400 mb-0.5">Duration</p>
                    <p class="text-xs font-semibold text-slate-700" id="infoDuration">—</p>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-400 mb-0.5">ROI</p>
                    <p class="text-xs font-semibold text-slate-700" id="infoRoi">—</p>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-400 mb-0.5">Daily ROI</p>
                    <p class="text-xs font-semibold text-emerald-700" id="infoDailyRoi">—</p>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-400 mb-0.5">Interest Type</p>
                    <p class="text-xs font-semibold text-slate-700" id="infoType">—</p>
                  </div>
                </div>
                
                <div>
                  <label class="text-xs font-medium text-slate-500 mb-1.5 block">Investment Amount</label>
                  <div class="relative">
                    <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-sm text-slate-400 font-medium">$</span>
                    <input type="number" id="calcAmount" step="0.01" class="w-full border border-slate-200 rounded-lg pl-9 pr-4 py-2.5 text-sm font-semibold text-slate-800 placeholder:text-slate-300 focus:ring-2 focus:ring-slate-300 focus:border-slate-300 transition outline-none" placeholder="0.00">
                  </div>
                  <p id="rangeText" class="text-[10px] text-slate-400 mt-1.5">—</p>
                </div>
                
                <button id="calculateBtn" class="w-full bg-slate-800 text-white py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-700 transition disabled:opacity-30 disabled:cursor-not-allowed">
                  Calculate Returns
                </button>
              </div>
            </div>
            
            <!-- All Plans Table -->
            <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
              <div class="px-5 py-3.5 border-b border-slate-100 flex items-center justify-between">
                <h2 class="text-sm font-semibold text-slate-800">All Plans at a Glance</h2>
                <p class="text-[10px] text-slate-400">Based on $10,000 principal</p>
              </div>
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead class="bg-slate-50 border-b border-slate-100">
                    <tr class="text-[10px] font-semibold text-slate-400 uppercase tracking-wide">
                      <th class="px-5 py-2.5 text-left">Plan</th>
                      <th class="px-5 py-2.5 text-right">Duration</th>
                      <th class="px-5 py-2.5 text-right">Rate</th>
                      <th class="px-5 py-2.5 text-right">Returns</th>
                      <th class="px-5 py-2.5 text-right">Profit</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="border-b border-slate-50">
                      <td class="px-5 py-2.5 text-xs font-semibold text-slate-700">108 Circle</td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">1 month</td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">200%</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-slate-700 text-right">$30,000.00</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-emerald-700 text-right">+$20,000.00</td>
                    </tr>
                    <tr class="border-b border-slate-50">
                      <td class="px-5 py-2.5 text-xs font-semibold text-slate-700">2222 Investment</td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">1 month</td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">200%</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-slate-700 text-right">$30,000.00</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-emerald-700 text-right">+$20,000.00</td>
                    </tr>
                    <tr class="border-b border-slate-50 bg-blue-50/30">
                      <td class="px-5 py-2.5 text-xs font-semibold text-slate-700">
                        8888 Investment
                        <span class="text-[7px] font-semibold uppercase text-blue-600 bg-blue-50 border border-blue-200/50 rounded px-1 py-px ml-1">Popular</span>
                      </td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">1 month</td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">300%</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-slate-700 text-right">$40,000.00</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-emerald-700 text-right">+$30,000.00</td>
                    </tr>
                    <tr class="border-b border-slate-50">
                      <td class="px-5 py-2.5 text-xs font-semibold text-slate-700">
                        Tier 3 Investment
                        <span class="text-[7px] font-semibold uppercase text-blue-600 bg-blue-50 border border-blue-200/50 rounded px-1 py-px ml-1">Popular</span>
                      </td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">1 month</td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">350%</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-slate-700 text-right">$45,000.00</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-emerald-700 text-right">+$35,000.00</td>
                    </tr>
                    <tr class="bg-blue-50/30">
                      <td class="px-5 py-2.5 text-xs font-semibold text-slate-700">
                        Bitcoin Elite Group
                        <span class="text-[7px] font-semibold uppercase text-blue-600 bg-blue-50 border border-blue-200/50 rounded px-1 py-px ml-1">Popular</span>
                      </td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">2 weeks</td>
                      <td class="px-5 py-2.5 text-[11px] text-slate-500 text-right">750%</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-slate-700 text-right">$85,000.00</td>
                      <td class="px-5 py-2.5 text-[11px] font-semibold text-emerald-700 text-right">+$75,000.00</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
          
          <!-- Right Column - Results Panel -->
          <div class="lg:col-span-2">
            <div id="placeholderPanel" class="bg-white border border-dashed border-slate-200 rounded-xl p-8 text-center">
              <svg class="mx-auto w-8 h-8 text-slate-300 mb-3" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Z"/>
              </svg>
              <p class="text-[11px] text-slate-400">Select a plan and enter an<br>amount to see projected returns.</p>
            </div>
            
            <div id="resultsPanel" class="bg-white border border-slate-200 rounded-xl overflow-hidden" style="display: none;">
              <div class="px-5 py-3.5 border-b border-slate-100">
                <h2 class="text-sm font-semibold text-slate-800">Projected Returns</h2>
              </div>
              <div class="divide-y divide-slate-50">
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Plan</span><span class="text-xs font-semibold text-slate-700" id="resPlan">—</span></div>
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Principal</span><span class="text-xs font-semibold text-slate-700" id="resPrincipal">—</span></div>
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Duration</span><span class="text-xs font-medium text-slate-700" id="resDuration">—</span></div>
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Daily ROI</span><span class="text-xs font-semibold text-emerald-700" id="resDailyRoi">—</span></div>
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Interest Type</span><span class="text-xs font-medium text-slate-700" id="resType">—</span></div>
                <div class="flex justify-between px-5 py-3 bg-slate-50/80"><span class="text-[11px] font-medium text-slate-500">Total Return</span><span class="text-sm font-semibold text-emerald-700" id="resTotal">—</span></div>
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Profit</span><span class="text-xs font-semibold text-emerald-700" id="resProfit">—</span></div>
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Effective ROI</span><span class="text-xs font-semibold text-emerald-700" id="resEffectiveRoi">—</span></div>
                <div class="flex justify-between px-5 py-3"><span class="text-[11px] text-slate-400">Maturity Date</span><span class="text-xs font-medium text-slate-700" id="resMaturity">—</span></div>
              </div>
              <div class="border-t border-slate-100 px-5 py-3.5">
                <a id="investLink" href="/dashboard/new-investment" class="block w-full text-center bg-slate-800 text-white py-2.5 rounded-lg text-sm font-semibold hover:bg-slate-700 transition">
                  Invest This Amount
                </a>
              </div>
            </div>
            
            <!-- Formula Info -->
            <div class="mt-4 px-4 py-3 bg-white border border-slate-200 rounded-xl">
              <div class="flex items-start gap-2.5">
                <svg class="w-3.5 h-3.5 text-slate-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"/>
                </svg>
                <div class="text-[10px] text-slate-400 leading-relaxed">
                  <p><span class="font-medium text-slate-500">Compound:</span> A = P × (1 + r)<sup>n</sup></p>
                  <p class="mt-0.5"><span class="font-medium text-slate-500">Simple:</span> A = P × (1 + r × n)</p>
                  <p class="mt-1">Same formulas used across the platform.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const planSelect = document.getElementById('calcPlan');
    const amountInput = document.getElementById('calcAmount');
    const calculateBtn = document.getElementById('calculateBtn');
    const placeholderPanel = document.getElementById('placeholderPanel');
    const resultsPanel = document.getElementById('resultsPanel');
    const rangeText = document.getElementById('rangeText');
    
    function updatePlanInfo() {
      const option = planSelect.options[planSelect.selectedIndex];
      const min = parseFloat(option.dataset.min);
      const max = parseFloat(option.dataset.max);
      const roi = parseFloat(option.dataset.roi);
      const days = parseInt(option.dataset.days);
      const type = option.dataset.type;
      const durationDisplay = days === 30 ? '1 month' : days === 14 ? '2 weeks' : days + ' days';
      
      document.getElementById('infoDuration').textContent = durationDisplay;
      document.getElementById('infoRoi').textContent = roi + '% ROI';
      document.getElementById('infoDailyRoi').textContent = (roi / days).toFixed(2) + '%';
      document.getElementById('infoType').textContent = type === 'compound' ? 'Compound' : 'Simple';
      rangeText.textContent = `Range: $${min.toLocaleString()} – $${max === 1000000 ? '1,000,000' : max.toLocaleString()}`;
    }
    
    function calculateReturns() {
      const option = planSelect.options[planSelect.selectedIndex];
      const amount = parseFloat(amountInput.value);
      const min = parseFloat(option.dataset.min);
      const max = parseFloat(option.dataset.max);
      const roi = parseFloat(option.dataset.roi);
      const days = parseInt(option.dataset.days);
      const type = option.dataset.type;
      const planName = option.dataset.name;
      
      if (!amount || amount <= 0) {
        alert('Please enter a valid amount');
        return;
      }
      
      if (amount < min) {
        alert(`Minimum investment is $${min.toLocaleString()}`);
        return;
      }
      
      if (amount > max) {
        alert(`Maximum investment is $${max.toLocaleString()}`);
        return;
      }
      
      let totalReturn, profit, effectiveRoi;
      const rate = roi / 100;
      const months = days / 30;
      
      if (type === 'compound') {
        totalReturn = amount * Math.pow(1 + rate, months);
      } else {
        totalReturn = amount * (1 + rate);
      }
      
      profit = totalReturn - amount;
      effectiveRoi = (profit / amount) * 100;
      
      const maturityDate = new Date();
      maturityDate.setDate(maturityDate.getDate() + days);
      
      document.getElementById('resPlan').textContent = planName;
      document.getElementById('resPrincipal').textContent = `$${amount.toLocaleString()}`;
      document.getElementById('resDuration').textContent = days === 30 ? '1 month' : days === 14 ? '2 weeks' : days + ' days';
      document.getElementById('resDailyRoi').textContent = (roi / days).toFixed(2) + '%';
      document.getElementById('resType').textContent = type === 'compound' ? 'Compound' : 'Simple';
      document.getElementById('resTotal').textContent = `$${totalReturn.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',')}`;
      document.getElementById('resProfit').textContent = `+$${profit.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',')}`;
      document.getElementById('resEffectiveRoi').textContent = effectiveRoi.toFixed(2) + '%';
      document.getElementById('resMaturity').textContent = maturityDate.toLocaleDateString();
      
      placeholderPanel.style.display = 'none';
      resultsPanel.style.display = 'block';
    }
    
    planSelect.addEventListener('change', updatePlanInfo);
    calculateBtn.addEventListener('click', calculateReturns);
    updatePlanInfo();
  </script>
</body>
</html>
