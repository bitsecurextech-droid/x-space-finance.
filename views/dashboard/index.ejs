<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>Dashboard - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.2s; color: #64748b; }
    .sidebar-link:hover { background: #f1f5f9; color: #1e293b; }
    .sidebar-link.active { background: #e0f2fe; color: #0284c7; }
    .sidebar-icon { width: 20px; height: 20px; }
    .topbar { background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 40; }
    .stat-card { background: white; border-radius: 20px; border: 1px solid #e2e8f0; padding: 20px; transition: all 0.2s; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 25px -6px rgba(0,0,0,0.08); }
    .action-btn { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 12px 16px; border-radius: 16px; background: white; border: 1px solid #e2e8f0; transition: all 0.2s; }
    .action-btn:hover { transform: translateY(-3px); border-color: #3b82f6; box-shadow: 0 8px 20px -10px rgba(59,130,246,0.2); }
    .progress-step { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: 12px; background: #f8fafc; border: 1px solid #e2e8f0; }
    .step-completed { background: #f0fdf4; border-color: #bbf7d0; }
    .step-active { background: #eff6ff; border-color: #bfdbfe; }
  </style>
</head>
<body>

<div class="flex">
  <%- include('../partials/complete-sidebar') %>

  <div class="flex-1 lg:ml-64">
    <%- include('../partials/topbar') %>

    <div class="p-6">
      <!-- Stats -->
      <div class="grid grid-cols-1 mb-4">
        <div class="stat-card bg-gradient-to-br from-blue-50 to-white border-blue-100">
          <p class="text-sm text-slate-500">Total Portfolio Value</p>
          <p class="text-3xl font-bold text-slate-800"><%= formatCurrency(portfolioValue || 0, user?.currency) %></p>
          <p class="text-xs text-slate-400 mt-1">Available: <%= formatCurrency(availableBalance || 0, user?.currency) %></p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="stat-card">
          <p class="text-sm text-slate-500">Invested</p>
          <p class="text-2xl font-bold text-slate-800"><%= formatCurrency(totalInvested || 0, user?.currency) %></p>
          <p class="text-xs text-slate-400 mt-1"><%= activeCount || 0 %> active plans</p>
        </div>
        <div class="stat-card">
          <p class="text-sm text-slate-500">Est. Returns</p>
          <p class="text-2xl font-bold text-emerald-600"><%= formatCurrency(totalExpectedReturn || 0, user?.currency) %></p>
          <p class="text-xs text-slate-400 mt-1">From active investments</p>
        </div>
<div class="stat-card">
  <p class="text-sm text-slate-500">Realized</p>
  <p class="text-2xl font-bold text-emerald-600"><%= formatCurrency(realizedReturn || 0, user?.currency) %></p>
  <p class="text-xs text-slate-400 mt-1">Matured returns</p>
</div>
        <div class="stat-card bg-gradient-to-r from-blue-50 to-white">
          <p class="text-sm text-slate-500">Available Balance</p>
          <p class="text-2xl font-bold text-blue-600"><%= formatCurrency(user?.balance || 0, user?.currency) %></p>
          <p class="text-xs text-slate-400 mt-1">Ready to invest</p>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
        <a href="/dashboard/deposits" class="action-btn">
          <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
          </svg>
          <span class="text-sm font-medium text-slate-700">Deposit</span>
          <span class="text-xs text-slate-400">Add funds</span>
        </a>
        <a href="/dashboard/new-investment" class="action-btn">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M12 4.5v15m7.5-7.5h-15"/>
          </svg>
          <span class="text-sm font-medium text-slate-700">Invest</span>
          <span class="text-xs text-slate-400">New plan</span>
        </a>
        <a href="/dashboard/withdrawals" class="action-btn">
          <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/>
          </svg>
          <span class="text-sm font-medium text-slate-700">Withdraw</span>
          <span class="text-xs text-slate-400">Cash out</span>
        </a>
        <a href="/dashboard/calculator" class="action-btn">
          <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Z"/>
          </svg>
          <span class="text-sm font-medium text-slate-700">Calculator</span>
          <span class="text-xs text-slate-400">Estimate returns</span>
        </a>
      </div>

      <!-- Checklist -->
      <div class="bg-white rounded-xl border border-slate-200 p-5 mb-8">
        <h3 class="font-semibold text-slate-800 mb-4">Welcome! Let's get started</h3>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
          <div class="progress-step <%= isEmailVerified ? 'step-completed' : 'step-active' %>">
            <div class="w-6 h-6 <%= isEmailVerified ? 'bg-green-500' : 'bg-blue-500' %> rounded-full flex items-center justify-center">
              <% if (isEmailVerified) { %>
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <span class="text-white text-xs font-bold">1</span>
              <% } %>
            </div>
            <div>
              <span class="text-sm font-medium text-slate-700">Verify your email</span>
              <% if (!isEmailVerified) { %><a href="#" class="text-xs text-blue-600 block">Resend</a><% } %>
            </div>
          </div>
          <div class="progress-step <%= isKycVerified ? 'step-completed' : 'step-active' %>">
            <div class="w-6 h-6 <%= isKycVerified ? 'bg-green-500' : 'bg-blue-500' %> rounded-full flex items-center justify-center">
              <% if (isKycVerified) { %>
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <span class="text-white text-xs font-bold">2</span>
              <% } %>
            </div>
            <div>
              <span class="text-sm font-medium text-slate-700">Complete identity verification</span>
              <% if (!isKycVerified) { %><a href="/dashboard/kyc" class="text-xs text-blue-600 block">Submit →</a><% } %>
            </div>
          </div>
          <div class="progress-step <%= hasDeposit ? 'step-completed' : '' %>">
            <div class="w-6 h-6 <%= hasDeposit ? 'bg-green-500' : 'bg-slate-300' %> rounded-full flex items-center justify-center">
              <% if (hasDeposit) { %>
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <span class="text-white text-xs font-bold">3</span>
              <% } %>
            </div>
            <div>
              <span class="text-sm font-medium text-slate-700">Fund your account</span>
              <% if (!hasDeposit) { %><a href="/dashboard/deposits" class="text-xs text-blue-600 block">Deposit →</a><% } %>
            </div>
          </div>
          <div class="progress-step <%= hasInvestment ? 'step-completed' : '' %>">
            <div class="w-6 h-6 <%= hasInvestment ? 'bg-green-500' : 'bg-slate-300' %> rounded-full flex items-center justify-center">
              <% if (hasInvestment) { %>
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
              <% } else { %>
                <span class="text-white text-xs font-bold">4</span>
              <% } %>
            </div>
            <div>
              <span class="text-sm font-medium text-slate-700">Start your first investment</span>
              <% if (!hasInvestment) { %><a href="/dashboard/new-investment" class="text-xs text-blue-600 block">Choose plan →</a><% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Active Investments & Recent Transactions -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center">
            <h3 class="font-semibold text-slate-800">Active Investments</h3>
            <a href="/dashboard/active-plans" class="text-xs text-blue-600 hover:underline">View all</a>
          </div>
          <% if (activeInvestments && activeInvestments.length > 0) { %>
            <div class="divide-y divide-slate-100">
              <% activeInvestments.forEach(inv => { %>
                <div class="px-5 py-3 flex justify-between items-center">
                  <div>
                    <p class="font-medium text-slate-800"><%= inv.plan_name || 'Plan' %></p>
                    <p class="text-xs text-slate-400"><%= formatCurrency(inv.amount || 0, user?.currency) %> · <%= inv.roi_percent || 0 %>% ROI</p>
                  </div>
                  <span class="text-xs font-medium text-emerald-600">Active</span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="p-8 text-center">
              <svg class="w-12 h-12 mx-auto text-slate-300 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <p class="text-slate-500 text-sm">No active investments yet</p>
              <a href="/dashboard/new-investment" class="inline-block mt-3 text-sm text-blue-600 hover:underline">Start investing →</a>
            </div>
          <% } %>
        </div>

        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center">
            <h3 class="font-semibold text-slate-800">Recent Transactions</h3>
            <a href="/dashboard/transactions" class="text-xs text-blue-600 hover:underline">Full history</a>
          </div>
          <% if (recentTransactions && recentTransactions.length > 0) { %>
            <div class="divide-y divide-slate-100">
              <% recentTransactions.forEach(tx => { %>
                <div class="px-5 py-3 flex justify-between items-center">
                  <div>
                    <p class="font-medium text-slate-800 capitalize"><%= tx.type || 'transaction' %></p>
                    <p class="text-xs text-slate-400"><%= new Date(tx.created_at).toLocaleDateString() %></p>
                  </div>
                  <span class="text-sm font-medium <%= (tx.amount || 0) >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
                    <%= (tx.amount || 0) >= 0 ? '+' : '' %><%= formatCurrency(tx.amount || 0, user?.currency) %>
                  </span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="p-8 text-center">
              <svg class="w-12 h-12 mx-auto text-slate-300 mb-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25"/></svg>
              <p class="text-slate-500 text-sm">No transactions yet</p>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Referral -->
      <div class="mt-6 bg-gradient-to-r from-slate-800 to-slate-900 rounded-xl p-5 text-white">
        <div class="flex justify-between items-center flex-wrap gap-4">
          <div>
            <h3 class="font-semibold">Referral Program</h3>
            <p class="text-slate-300 text-sm mt-1">Share your code and earn referral bonuses.</p>
            <div class="flex gap-2 mt-3">
              <code class="bg-slate-700 px-3 py-1.5 rounded text-sm"><%= user?.referral_code || 'N/A' %></code>
              <button onclick="copyReferralCode()" class="bg-slate-700 px-3 py-1.5 rounded text-sm hover:bg-slate-600 transition">Copy</button>
            </div>
          </div>
          <div class="text-right">
            <p class="text-2xl font-bold"><%= formatCurrency(referralEarnings || 0, user?.currency) %></p>
            <p class="text-slate-300 text-xs">Total earned</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function copyReferralCode() {
    const code = '<%= user?.referral_code || '' %>';
    if (navigator.clipboard) {
      navigator.clipboard.writeText(code).then(() => alert('Copied!'));
    } else {
      const input = document.createElement('input');
      input.value = code;
      document.body.appendChild(input);
      input.select();
      document.execCommand('copy');
      document.body.removeChild(input);
      alert('Copied!');
    }
  }
</script>
</body>
</html>
