<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Manage Users - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>.sidebar-item { transition: all 0.2s ease; } .sidebar-item:hover { background: rgba(59, 130, 246, 0.1); color: #3b82f6; } .sidebar-item.active { background: rgba(59, 130, 246, 0.15); color: #3b82f6; border-left: 3px solid #3b82f6; }</style>
</head>
<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
  <%- include('../partials/admin-sidebar') %>
  <div class="lg:ml-72 min-h-screen">
    <div class="bg-slate-800/50 border-b border-slate-700 px-6 py-4"><h1 class="text-2xl font-bold bg-gradient-to-r from-white to-blue-400 bg-clip-text text-transparent">Manage Users</h1><p class="text-slate-400 text-sm">View, search, and manage all platform users</p></div>
    <div class="p-6">
      <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden">
        <div class="p-4 border-b border-slate-700"><div class="flex gap-4"><input type="text" id="searchInput" placeholder="Search by name or email..." class="flex-1 bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white"><select id="kycFilter" class="bg-slate-700 border border-slate-600 rounded-lg px-4 py-2"><option value="all">All KYC</option><option value="approved">Approved</option><option value="pending">Pending</option><option value="unverified">Unverified</option></select></div></div>
        <div class="overflow-x-auto"><table class="w-full"><thead class="bg-slate-700/50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">User</th><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Email</th><th class="px-6 py-3 text-right text-xs font-medium text-slate-400 uppercase">Balance</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">KYC</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Status</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Admin</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Actions</th></tr></thead><tbody id="usersTableBody"><% users.forEach(function(u) { %><tr class="border-t border-slate-700 hover:bg-slate-700/30 transition" data-name="<%= u.first_name %> <%= u.last_name %>".toLowerCase() data-email="<%= u.email %>".toLowerCase() data-kyc="<%= u.kyc_status || 'unverified' %>"><td class="px-6 py-4 font-medium"><%= u.first_name %> <%= u.last_name %></td><td class="px-6 py-4 text-slate-300"><%= u.email %></td><td class="px-6 py-4 text-right font-mono"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: u.currency || 'USD' }).format(u.balance) %></td><td class="px-6 py-4 text-center"><span class="px-2 py-1 rounded text-xs <%= u.kyc_status === 'approved' ? 'bg-green-500/20 text-green-400' : u.kyc_status === 'pending' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-slate-600 text-slate-400' %>"><%= u.kyc_status || 'unverified' %></span></td><td class="px-6 py-4 text-center"><span class="px-2 py-1 rounded text-xs <%= u.is_banned ? 'bg-red-500/20 text-red-400' : 'bg-green-500/20 text-green-400' %>"><%= u.is_banned ? 'Banned' : 'Active' %></span></td><td class="px-6 py-4 text-center"><span class="px-2 py-1 rounded text-xs <%= u.is_admin ? 'bg-purple-500/20 text-purple-400' : 'bg-slate-600 text-slate-400' %>"><%= u.is_admin ? 'Admin' : 'User' %></span></td><td class="px-6 py-4 text-center"><div class="flex items-center justify-center gap-2"><a href="/admin/user/<%= u.id %>" class="px-3 py-1 bg-blue-600 rounded-lg text-sm hover:bg-blue-700">Manage</a><form method="POST" action="/admin/user/<%= u.id %>/delete" onsubmit="return confirm('Delete this user?')" class="inline"><button type="submit" class="px-3 py-1 bg-red-600 rounded-lg text-sm hover:bg-red-700 transition">Delete</button></form></div></td></tr><% }); %></tbody></table></div>
      </div>
    </div>
  </div>
  <script>
    document.getElementById('searchInput')?.addEventListener('keyup', filterUsers);
    document.getElementById('kycFilter')?.addEventListener('change', filterUsers);
    function filterUsers() { const search = document.getElementById('searchInput').value.toLowerCase(); const kyc = document.getElementById('kycFilter').value; const rows = document.querySelectorAll('#usersTableBody tr'); rows.forEach(row => { const name = row.dataset.name || row.cells[0]?.innerText.toLowerCase(); const email = row.dataset.email || row.cells[1]?.innerText.toLowerCase(); const kycStatus = row.dataset.kyc || (row.cells[3]?.innerText.toLowerCase().includes('approved') ? 'approved' : row.cells[3]?.innerText.toLowerCase().includes('pending') ? 'pending' : 'unverified'); const matchesSearch = !search || name.includes(search) || email.includes(search); const matchesKyc = kyc === 'all' || kycStatus === kyc; row.style.display = matchesSearch && matchesKyc ? '' : 'none'; }); }
  </script>
</body>
</html>
